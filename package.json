{
  "name": "blockhost-engine-evm",
  "version": "0.2.0",
  "description": "Subscription management system with EVM smart contracts and monitoring server",
  "bin": {
    "bw": "./src/bw/index.ts",
    "ab": "./src/ab/index.ts"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
