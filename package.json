    "clean": "hardhat clean",
    "monitor": "npx tsx src/monitor/index.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "hardhat": "^2.19.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
